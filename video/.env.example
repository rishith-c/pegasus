# Video service (Rishith). Copy to .env and fill in. NEVER commit .env.
NVIDIA_STT_KEY=nvapi-...
NVIDIA_TTS_KEY=nvapi-...
# Hosted NVIDIA Riva over gRPC (defaults below). Override the TTS function-id
# to switch voices/models; default is Resemble.AI Chatterbox multilingual TTS.
# NVIDIA_RIVA_SERVER=grpc.nvcf.nvidia.com:443
# NVIDIA_TTS_FUNCTION_ID=ddacc747-1269-4fab-bfd9-8f593dead106   # chatterbox
# NVIDIA_ASR_FUNCTION_ID=1598d209-5e27-4d3c-8079-4751568b1081   # parakeet en-US
# NVIDIA_TTS_VOICE=
